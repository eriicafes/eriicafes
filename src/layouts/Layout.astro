---
import { Font } from "astro:assets";
import GithubIcon from "../components/icons/GithubIcon.astro";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Eric Afes - About Me" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <Font cssVariable="--font-geist" />
  </head>
  <body
    class="bg-white text-neutral-900 antialiased dark:bg-neutral-950 dark:text-neutral-100"
  >
    <header
      class="mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-x-4 gap-y-2 px-4 py-5 sm:px-6"
    >
      <a href="/" class="text-sm font-medium hover:underline underline-offset-2"
        >Eric Afes</a
      >
      <nav
        class="order-3 flex w-full flex-wrap gap-x-4 gap-y-1 sm:order-0 sm:w-auto"
      >
        <a
          href="/blog"
          class="text-sm text-neutral-600 underline underline-offset-4 transition-colors hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100"
          >Blog</a
        >
      </nav>
      <a
        href="https://github.com/eriicafes"
        target="_blank"
        rel="noreferrer"
        aria-label="GitHub profile"
        class="text-neutral-600 transition-colors hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100"
      >
        <GithubIcon class="size-6" />
      </a>
    </header>
    <slot />
  </body>
</html>
